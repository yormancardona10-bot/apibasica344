<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div>
            <h1>Clientes</h1>
            <table id="tabla">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>email</th>
                        <th>Telefono</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(function(cliente) { %>
                        <tr>
                            <td><%= cliente.nombre %></td>
                            <td><%= cliente.email %></td>
                            <td><%= cliente.telefono %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>
</html>