<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div>
            <h1>Clientes</h1>
            <table id="tabla" class="table table-striped">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Telefono</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(function(cliente) { %>
                        <tr>
                            <td><%= cliente.nombre %></td>
                            <td><%= cliente.email %></td>
                            <td><%= cliente.telefono %></td>
                            <td>
                                <a href="/clientes/editar/<%= cliente._id %>" class="btn btn-warning btn-sm">Editar</a>
                                <button class="btn btn-danger btn-sm" onclick="eliminar('/clientes/<%= cliente._id %>')">Eliminar</button>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

    <a href="/clientes/eliminar/<%= cliente._id %>" class="btn btn-danger btn-sm">Eliminar</a>

</body>
</html>